[7.977818, "o", "\u001b[2;95m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[95m \u25c6 response \u25c6 \u001b[0m\u001b[2;95m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500"]
[7.989818, "o", "\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\nYes \u2014 \u001b[1;36;40mcl\u001b[0m adds \u001b[1;36;40m.cl_history/\u001b[0m (a legacy path) \u001b[1mand\u001b[0m \u001b[1;36;40m~/.local/cl/ses"]
[8.001818, "o", "sions/\u001b[0m to your global git excludes    \nautomatically on first run, so session files never appear as untracked change"]
[8.013818, "o", "s inside your projects.\n\nThe git excludes file (\u001b[1;36;40mcore.excludesFile\u001b[0m in \u001b[1;36;40m~/.gitconfig\u001b[0m) is update"]
[8.025818, "o", "d with a single \u001b[1;36;40mgit config \u001b[0m      \n\u001b[1;36;40m--global\u001b[0m call; no shell redirection is used.              "]
[8.037818, "o", "                                          \n\n\u001b[2;95m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[95m \u25c6 metadata \u25c6 \u001b[0"]
